generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IngredientType {
  base
  additional
}

enum DrinkSize {
  small
  medium
  large
}

enum ConsumptionType {
  local
  takeaway
}

enum PaymentMethod {
  credit
  debit
  pix
}

enum OrderStatus {
  received
  preparing
  ready
  delivered
  cancelled
}

model Drink {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  image       String
  ingredients String[]
  price       Float
  createdAt   DateTime @default(now())

  orderItems OrderItem[]
}

model Ingredient {
  id        Int            @id @default(autoincrement())
  name      String
  type      IngredientType
  price     Float
  available Boolean        @default(true)
  createdAt DateTime       @default(now())
}

model CustomDrink {
  id            Int             @id @default(autoincrement())
  generatedName String
  ingredients   String[]
  totalPrice    Float
  size          DrinkSize
  consumption   ConsumptionType
  createdAt     DateTime        @default(now())

  orderItems OrderItem[]
}

model Customer {
  id    Int     @id @default(autoincrement())
  name  String
  email String?
  phone String?

  createdAt DateTime @default(now())

  orders Order[]
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique
  totalPrice  Float

  paymentMethod PaymentMethod
  status        OrderStatus

  consumptionType ConsumptionType

  createdAt DateTime @default(now())

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  items OrderItem[]
}

model OrderItem {
  id            Int @id @default(autoincrement())

  quantity      Int
  unitPrice     Float

  drinkId       Int?
  drink         Drink? @relation(fields: [drinkId], references: [id])

  customDrinkId Int?
  customDrink   CustomDrink? @relation(fields: [customDrinkId], references: [id])

  orderId       Int
  order         Order @relation(fields: [orderId], references: [id])
}